# Jira Configuration
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
# Your personal Jira account ID — get it from: https://your-jira.atlassian.net/rest/api/3/myself
JIRA_USER_ID=your-jira-account-id

# GitHub Configuration
GITHUB_PAT=ghp_your-github-personal-access-token

# Jenkins Configuration
JENKINS_URL=https://your-jenkins-url
JENKINS_USER=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token

# Optional: override default notification recipients (space-separated)
# GITHUB_NOTIFY_EMAILS=person1@example.com person2@example.com
